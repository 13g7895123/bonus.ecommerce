COMPOSE_PROJECT_NAME=ecommerce
FRONTEND_PORT=8104
BACKEND_PORT=8204
DB_PORT=8304
PHPMYADMIN_PORT=8404

# Database
DB_DATABASE=ecommerce_db
DB_USERNAME=ecommerce
DB_PASSWORD=ecommerce123
DB_ROOT_PASSWORD=rootpassword

# Backend
JWT_SECRET=supersecretjwtkey12345678901234567890ab
JWT_EXPIRE=86400

# SMS / Twilio（在 Twilio Console 取得後填入）
# TWILIO_ACCOUNT_SID:        Twilio Console → Account Info → Account SID
# TWILIO_AUTH_TOKEN:         Twilio Console → Account Info → Auth Token
# TWILIO_VERIFY_SERVICE_SID: Twilio Console → Verify → Services → 建立 Service 後複製 Service SID
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_SERVICE_SID=VSxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
